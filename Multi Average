//@version=6
indicator("Multi Average", overlay=true)

// User inputs
length = input.int(20, title="Length", minval=1)
priceSource = input.source(close, title="Price Source")

// ALMA specific inputs
offset = input.float(0.85, title="ALMA Offset", minval=0, maxval=1)
sigma  = input.float(6, title="ALMA Sigma", minval=0.1)

// Moving average calculations
smaValue    = ta.sma(priceSource, length)
emaValue    = ta.ema(priceSource, length)
vwmaValue   = ta.vwma(priceSource, length)
hmaValue    = ta.hma(priceSource, length)
lsmaValue   = ta.linreg(priceSource, length, 0)
medianValue = ta.median(priceSource, length)
smmaValue   = ta.rma(priceSource, length)
almaValue   = ta.alma(priceSource, length, offset, sigma)

// Always plot (no toggles)
plot(smaValue,    title="SMA Line",    color=color.blue,    linewidth=2)
plot(emaValue,    title="EMA Line",    color=color.red,     linewidth=2)
plot(vwmaValue,   title="VWMA Line",   color=color.green,   linewidth=2)
plot(hmaValue,    title="HMA Line",    color=color.purple,  linewidth=2)
plot(lsmaValue,   title="LSMA Line",   color=color.orange,  linewidth=2)
plot(medianValue, title="Median Line", color=color.teal,    linewidth=2)
plot(smmaValue,   title="SMMA Line",   color=color.fuchsia, linewidth=2)
plot(almaValue,   title="ALMA Line",   color=color.yellow,  linewidth=2)

// Table (fixed rows now)
var table avgTable = table.new(position.top_right, 2, 8, border_width=1)

if barstate.islast
    table.cell(avgTable, 0, 0, "SMA",    text_color=color.white, bgcolor=color.blue)
    table.cell(avgTable, 1, 0, str.tostring(smaValue, format.mintick))

    table.cell(avgTable, 0, 1, "EMA",    text_color=color.white, bgcolor=color.red)
    table.cell(avgTable, 1, 1, str.tostring(emaValue, format.mintick))

    table.cell(avgTable, 0, 2, "VWMA",   text_color=color.white, bgcolor=color.green)
    table.cell(avgTable, 1, 2, str.tostring(vwmaValue, format.mintick))

    table.cell(avgTable, 0, 3, "HMA",    text_color=color.white, bgcolor=color.purple)
    table.cell(avgTable, 1, 3, str.tostring(hmaValue, format.mintick))

    table.cell(avgTable, 0, 4, "LSMA",   text_color=color.white, bgcolor=color.orange)
    table.cell(avgTable, 1, 4, str.tostring(lsmaValue, format.mintick))

    table.cell(avgTable, 0, 5, "Median", text_color=color.white, bgcolor=color.teal)
    table.cell(avgTable, 1, 5, str.tostring(medianValue, format.mintick))

    table.cell(avgTable, 0, 6, "SMMA",   text_color=color.white, bgcolor=color.fuchsia)
    table.cell(avgTable, 1, 6, str.tostring(smmaValue, format.mintick))

    table.cell(avgTable, 0, 7, "ALMA",   text_color=color.black, bgcolor=color.yellow)
    table.cell(avgTable, 1, 7, str.tostring(almaValue, format.mintick))
